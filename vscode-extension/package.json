{
	"name": "oxidecode",
	"displayName": "OxideCode",
	"description": "AI autocomplete and next-edit suggestions powered by local and cloud models",
	"version": "0.2.6",
	"publisher": "oxidecode",
	"icon": "light.png",
	"engines": {
		"vscode": "^1.108.0"
	},
	"categories": [
		"AI",
		"Other"
	],
	"keywords": [
		"ai",
		"autocomplete",
		"code-completion",
		"copilot",
		"llm",
		"local-ai",
		"ollama",
		"nes",
		"next-edit-suggestions"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/NxtCore/OxideCode.git"
	},
	"homepage": "https://github.com/NxtCore/OxideCode#readme",
	"bugs": {
		"url": "https://github.com/NxtCore/OxideCode/issues"
	},
	"license": "MIT",
	"marketing": {
		"color": "#007ACC",
		"theme": "dark"
	},
	"galleryBanner": {
		"color": "#007ACC",
		"theme": "dark"
	},
	"badges": [
		{
			"url": "https://img.shields.io/badge/version-0.1.0-blue",
			"href": "https://github.com/NxtCore/OxideCode/releases",
			"description": "Version"
		},
		{
			"url": "https://img.shields.io/badge/license-MIT-green",
			"href": "https://github.com/NxtCore/OxideCode/blob/main/LICENSE",
			"description": "License"
		}
	],
	"qna": "https://github.com/NxtCore/OxideCode/discussions",
	"contributes": {
		"commands": [
			{
				"command": "sweep.triggerNextEdit",
				"title": "OxideCode: Trigger Next Edit Suggestion"
			},
			{
				"command": "sweep.toggleEnabled",
				"title": "OxideCode: Toggle Enabled"
			},
			{
				"command": "sweep.showMenu",
				"title": "OxideCode: Show Menu"
			},
			{
				"command": "sweep.acceptJumpEdit",
				"title": "OxideCode: Accept Jump Edit"
			},
			{
				"command": "sweep.acceptInlineEdit",
				"title": "OxideCode: Accept Inline Edit"
			},
			{
				"command": "sweep.dismissJumpEdit",
				"title": "OxideCode: Dismiss Jump Edit"
			}
		],
		"keybindings": [
			{
				"command": "sweep.acceptJumpEdit",
				"key": "tab",
				"when": "editorTextFocus && sweep.hasJumpEdit && !editorHasSelection && !inlineSuggestionVisible && !suggestWidgetVisible"
			},
			{
				"command": "sweep.acceptJumpEdit",
				"key": "alt+tab",
				"when": "editorTextFocus && sweep.hasJumpEdit && !editorHasSelection"
			},
			{
				"command": "sweep.acceptJumpEdit",
				"key": "alt+l",
				"when": "isLinux && editorTextFocus && sweep.hasJumpEdit && !editorHasSelection"
			},
			{
				"command": "sweep.dismissJumpEdit",
				"key": "escape",
				"when": "editorTextFocus && sweep.hasJumpEdit"
			},
			{
				"command": "editor.action.inlineSuggest.commit",
				"key": "alt+tab",
				"when": "editorTextFocus && inlineSuggestionVisible && suggestWidgetVisible && !editorHasSelection && !sweep.hasJumpEdit && !inSnippetMode"
			},
			{
				"command": "editor.action.inlineSuggest.commit",
				"key": "alt+l",
				"when": "isLinux && editorTextFocus && inlineSuggestionVisible && suggestWidgetVisible && !editorHasSelection && !sweep.hasJumpEdit && !inSnippetMode"
			},
			{
				"command": "editor.action.inlineSuggest.hide",
				"key": "escape",
				"when": "editorTextFocus && inlineSuggestionVisible && !suggestWidgetVisible && !sweep.hasJumpEdit"
			}
		],
		"configuration": {
			"title": "OxideCode",
			"properties": {
				"oxidecode.enabled": {
					"type": "boolean",
					"default": true,
					"scope": "window",
					"description": "Enable or disable OxideCode suggestions"
				},
				"oxidecode.backend": {
					"type": "string",
					"enum": [
						"native",
						"http"
					],
					"enumDescriptions": [
						"Use native Rust core via NAPI bindings (faster, requires native module)",
						"Use HTTP local server (slower, requires Python/uvx)"
					],
					"default": "native",
					"description": "Backend mode for inference requests"
				},
				"oxidecode.promptStyle": {
					"type": "string",
					"enum": [
						"generic",
						"sweep",
						"zeta1",
						"zeta2"
					],
					"enumDescriptions": [
						"Generic JSON-based prompt format",
						"Sweep AI next-edit format (recommended for sweep-next-edit models)",
						"Zed's legacy instruction-following format (for zeta v1 models)",
						"Zed's modern SPM FIM format (for zeta-2 / seed-coder models)"
					],
					"default": "sweep",
					"description": "Prompt style used for NES (Next-Edit Suggestion) requests"
				},
				"oxidecode.completionEndpoint": {
					"type": "string",
					"enum": [
						"completions",
						"chat_completions"
					],
					"enumDescriptions": [
						"Use /v1/completions (raw text, avoids chat-template framing)",
						"Use /v1/chat/completions (chat format, for instruction-tuned models)"
					],
					"default": "completions",
					"description": "HTTP endpoint type for inference requests"
				},
				"oxidecode.calibrationLogDir": {
					"type": "string",
					"default": "",
					"description": "When set, NES predictions are logged as JSONL files to this directory for calibration. Leave empty to disable."
				},
				"oxidecode.provider.baseUrl": {
					"type": "string",
					"default": "http://localhost:11434/v1",
					"description": "Base URL for the OpenAI-compatible inference server (e.g., Ollama, vLLM)"
				},
				"oxidecode.provider.apiKey": {
					"type": "string",
					"default": "",
					"description": "API key for the inference server (optional for local servers)"
				},
				"oxidecode.provider.model": {
					"type": "string",
					"default": "qwen2.5-coder:7b",
					"description": "Model name for NES and chat requests"
				},
				"oxidecode.provider.completionModel": {
					"type": "string",
					"default": "",
					"description": "Separate model for FIM completions (optional, uses main model if empty)"
				},
				"oxidecode.maxContextFiles": {
					"type": "number",
					"default": 5,
					"description": "Maximum number of recently viewed files to include as context"
				},
				"oxidecode.autocompleteExclusionPatterns": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [
						"**/.env*",
						"**/*.pem",
						"**/*.key",
						"**/*.cert",
						"**/*.crt",
						"**/.dev.vars",
						"**/secrets.yml"
					],
					"description": "File name suffixes or globs to exclude from autocomplete"
				},
				"oxidecode.autocompleteSnoozeUntil": {
					"type": "number",
					"default": 0,
					"description": "Unix timestamp (ms) until which autocomplete is snoozed (0 disables snooze)"
				},
				"oxidecode.localPort": {
					"type": "number",
					"default": 8081,
					"description": "Port for the local HTTP server (only used when backend is 'http')"
				}
			}
		}
	},
	"scripts": {
		"build": "bun build src/extension/activate.ts --outfile=out/extension.js --external=vscode --format=cjs --target=node",
		"build:native": "cd .. && cargo build --release -p oxidecode-node",
		"build:native:copy": "bun run build:native && node -e \"const fs=require('fs');const p=process.platform;const a=process.arch;fs.copyFileSync('../target/release/oxidecode_node'+(p==='win32'?'.dll':p==='darwin'?'.dylib':'.so'),'oxidecode.'+p+'-'+a+'.node')\"",
		"build:all": "bun run build:native:copy && bun run build",
		"build:native:linux-x64": "cargo zigbuild --release -p oxidecode-node --manifest-path ../Cargo.toml --target x86_64-unknown-linux-gnu && node -e \"require('fs').copyFileSync('../target/x86_64-unknown-linux-gnu/release/liboxidecode_node.so','oxidecode.linux-x64.node')\"",
		"build:native:darwin-arm64": "cargo zigbuild --release -p oxidecode-node --manifest-path ../Cargo.toml --target aarch64-apple-darwin && node -e \"require('fs').copyFileSync('../target/aarch64-apple-darwin/release/liboxidecode_node.dylib','oxidecode.darwin-arm64.node')\"",
		"build:native:darwin-x64": "cargo zigbuild --release -p oxidecode-node --manifest-path ../Cargo.toml --target x86_64-apple-darwin && node -e \"require('fs').copyFileSync('../target/x86_64-apple-darwin/release/liboxidecode_node.dylib','oxidecode.darwin-x64.node')\"",
		"build:native:win32-x64": "cargo zigbuild --release -p oxidecode-node --manifest-path ../Cargo.toml --target x86_64-pc-windows-msvc && node -e \"require('fs').copyFileSync('../target/x86_64-pc-windows-msvc/release/oxidecode_node.dll','oxidecode.win32-x64.node')\"",
		"build:native:all-platforms": "bun run build:native:linux-x64 && bun run build:native:darwin-arm64 && bun run build:native:darwin-x64 && bun run build:native:win32-x64",
		"typecheck": "bun tsgo --noEmit",
		"lint": "bun biome check .",
		"fix": "bun biome check . --write",
		"package": "bunx vsce package --no-dependencies",
		"package:all": "bun run build:all && bun run package",
		"package:universal": "bun run build && bun run package"
	},
	"files": [
		"out/**/*",
		"oxidecode.*.node",
		"light.png"
	],
	"dependencies": {
		"@shikijs/core": "^3.21.0",
		"@shikijs/engine-javascript": "^3.21.0",
		"@shikijs/langs": "^3.21.0",
		"@shikijs/themes": "^3.21.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@types/bun": "1.3.7",
		"@types/vscode": "1.108.1",
		"@typescript/native-preview": "7.0.0-dev.20260127.1"
	}
}
